# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# auth
browser.json
backups/

# python venv
.venv/

# radar state
radar/state.db
radar/state.db.wal

# temp sync artifacts
public/data/_albums_synced.json

# planning files (deep-plan artifacts)
claude-*.md
deep_plan_config.json
reviews/

# WASM files (copied at build time)
public/*.wasm
public/*.worker.js

# typescript
*.tsbuildinfo
next-env.d.ts

# Python + data backups
__pycache__/
*.pyc
public/data/_backups/
